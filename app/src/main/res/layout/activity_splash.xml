<?xml version="1.0" encoding="utf-8"?>
<!-- [SPLASH LAYOUT] Updated for Nivar UI/UX Overhaul -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/splash_gradient">

    <!-- Governance Icon (placeholder using existing logo) -->
    <ImageView android:id="@+id/ivLogo" android:layout_width="80dp" android:layout_height="80dp" android:src="@drawable/splash_logo" app:layout_constraintBottom_toTopOf="@id/tvAppName" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintVertical_chainStyle="packed" app:layout_constraintTop_toTopOf="parent" app:layout_constraintVertical_bias="0.42" android:contentDescription="Nivar Logo" />

    <!-- NIVAR Title -->
    <TextView android:id="@+id/tvAppName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NIVAR" android:textSize="36sp" android:textStyle="bold" android:textColor="@color/white" android:letterSpacing="0.2" android:layout_marginTop="16dp" app:layout_constraintTop_toBottomOf="@id/ivLogo" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />

    <!-- Tagline -->
    <TextView android:id="@+id/tvTagline" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Your Digital Gateway to Governance" android:textSize="14sp" android:textColor="#B0BEC5" android:letterSpacing="0.05" android:layout_marginTop="8dp" app:layout_constraintTop_toBottomOf="@id/tvAppName" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />

    <!-- Loading indicator -->
    <ProgressBar android:id="@+id/progressBar" style="@android:style/Widget.ProgressBar.Horizontal" android:layout_width="120dp" android:layout_height="4dp" android:indeterminate="true" android:indeterminateTint="#BDE8F5" android:layout_marginBottom="48dp" app:layout_constraintBottom_toTopOf="@id/tvInitText" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />

    <!-- Initializing text -->
    <TextView android:id="@+id/tvInitText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="INITIALIZING SECURELY" android:textSize="10sp" android:textColor="#607D8B" android:letterSpacing="0.3" android:layout_marginBottom="40dp" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
